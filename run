#!/usr/bin/env bash

set -euo pipefail

PROJECT_PACKAGE="${PROJECT_PACKAGE:-test}"

DO_CLEAN=0
DO_RUN=1
DO_BUILD=0
DO_VERBOSE=0

usage()
{
    cat >&2 <<'EOF'
Usage: ./run.sh [-c] [-r] [-b] [-v]

Options:
  -c    cargo clean only
  -r    cargo clean + cargo run
  -b    cargo build
  -v    verbose cargo output (-vv)

Default:
  cargo run
EOF
}

while getopts ":crbv" opt; do
    case "${opt}" in
        c)
            DO_CLEAN=1
            DO_RUN=0
            DO_BUILD=0
            ;;
        r)
            DO_CLEAN=1
            DO_RUN=1
            DO_BUILD=0
            ;;
        b)
            DO_CLEAN=0
            DO_RUN=0
            DO_BUILD=1
            ;;
        v)
            DO_VERBOSE=1
            ;;
        \?)
            usage
            exit 1
            ;;
    esac
done

if [[ -t 2 ]]; then
    R=$'\033[0m'
    B=$'\033[1m'
    D=$'\033[2m'

    RED=$'\033[1;31m'
    GRN=$'\033[1;32m'
    YEL=$'\033[1;33m'
    BLU=$'\033[1;34m'
    MAG=$'\033[1;35m'
    CYA=$'\033[1;36m'
    WHT=$'\033[1;37m'
else
    R='' B='' D=''
    RED='' GRN='' YEL='' BLU='' MAG='' CYA='' WHT=''
fi

line()
{
    printf '%b\n' "${D}------------------------------------------------------------------------------${R}" >&2
}

title()
{
    line
    printf '%b\n' "${B}${MAG} $*${R}" >&2
    line
}

section()
{
    printf '\n%b\n' "${B}${CYA}==> $*${R}" >&2
}

info()
{
    printf '%b\n' "${BLU}ℹ${R}  $*" >&2
}

ok()
{
    printf '%b\n' "${GRN}[Success]${R}  $*" >&2
}

warn()
{
    printf '%b\n' "${YEL}[Warn]${R}  $*" >&2
}

debug()
{
    printf '%b\n' "${D}· $*${R}" >&2
}

die()
{
    printf '%b\n' "${RED}[Error]${R}  $*" >&2
    exit 1
}

kv()
{
    local key="$1"
    local value="$2"
    printf '%b %b\n' "${WHT}${key}:${R}" "${value}" >&2
}

cmd()
{
    printf '%b %s\n' "${MAG}$${R}" "$*" >&2
}

step()
{
    printf '%b\n' "${B}${BLU}→${R}  $*" >&2
}

require_cmd()
{
    command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

load_os_release()
{
    [[ -r /etc/os-release ]] || die "/etc/os-release not found"
    # shellcheck disable=SC1091
    . /etc/os-release
}

print_runtime_config()
{
    section "Runtime configuration"
    kv "package" "${PROJECT_PACKAGE}"
    kv "clean"   "${DO_CLEAN}"
    kv "run"     "${DO_RUN}"
    kv "build"   "${DO_BUILD}"
    kv "verbose" "${DO_VERBOSE}"
}

diagnostic_shaderc()
{
    section "Shaderc diagnostics"

    if command -v pkg-config >/dev/null 2>&1; then
        ok "pkg-config detected"
    else
        warn "pkg-config not installed"
    fi

    if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists shaderc; then
        ok "pkg-config knows shaderc"
        kv "shaderc version" "$(pkg-config --modversion shaderc || true)"
        kv "shaderc libdir"  "$(pkg-config --variable=libdir shaderc || true)"
        kv "shaderc flags"   "$(pkg-config --libs --cflags shaderc || true)"
    else
        warn "pkg-config does not know shaderc"
    fi

    for path in \
        /usr/lib64 \
        /usr/lib/x86_64-linux-gnu \
        /usr/lib/aarch64-linux-gnu \
        /usr/lib/arm-linux-gnueabihf \
        /usr/lib \
        /usr/local/lib64 \
        /usr/local/lib
    do
        if compgen -G "${path}/libshaderc*" > /dev/null 2>&1; then
            ok "shaderc libraries found in ${path}"
            ls -1 "${path}"/libshaderc* 2>/dev/null >&2 || true
        else
            debug "no shaderc libraries in ${path}"
        fi
    done
}

install_packages()
{
    section "Installing shaderc packages"

    load_os_release
    kv "ID"      "${ID:-unknown}"
    kv "ID_LIKE" "${ID_LIKE:-unknown}"

    case "${ID:-}" in
        fedora)
            cmd "sudo dnf install -y libshaderc-devel libshaderc-static pkgconf-pkg-config cmake git python3"
            sudo dnf install -y \
                libshaderc-devel libshaderc-static \
                pkgconf-pkg-config cmake git python3
            ;;
        rhel|centos|rocky|almalinux)
            cmd "sudo dnf install -y shaderc-devel pkgconf-pkg-config cmake git python3"
            sudo dnf install -y \
                shaderc-devel \
                pkgconf-pkg-config cmake git python3
            ;;
        ubuntu|debian)
            cmd "sudo apt-get update"
            sudo apt-get update
            cmd "sudo apt-get install -y libshaderc-dev pkg-config cmake git python3"
            sudo apt-get install -y \
                libshaderc-dev \
                pkg-config cmake git python3
            ;;
        arch)
            cmd "sudo pacman -Sy --needed shaderc pkgconf cmake git python"
            sudo pacman -Sy --needed \
                shaderc pkgconf cmake git python
            ;;
        opensuse*|sles)
            cmd "sudo zypper --non-interactive install shaderc shaderc-devel pkg-config cmake git python3"
            sudo zypper --non-interactive install \
                shaderc shaderc-devel \
                pkg-config cmake git python3
            ;;
        *)
            case "${ID_LIKE:-}" in
                *fedora*|*rhel*)
                    cmd "sudo dnf install -y shaderc-devel pkgconf-pkg-config cmake git python3"
                    sudo dnf install -y \
                        shaderc-devel \
                        pkgconf-pkg-config cmake git python3
                    ;;
                *debian*)
                    cmd "sudo apt-get update"
                    sudo apt-get update
                    cmd "sudo apt-get install -y libshaderc-dev pkg-config cmake git python3"
                    sudo apt-get install -y \
                        libshaderc-dev \
                        pkg-config cmake git python3
                    ;;
                *arch*)
                    cmd "sudo pacman -Sy --needed shaderc pkgconf cmake git python"
                    sudo pacman -Sy --needed \
                        shaderc pkgconf cmake git python
                    ;;
                *suse*)
                    cmd "sudo zypper --non-interactive install shaderc shaderc-devel pkg-config cmake git python3"
                    sudo zypper --non-interactive install \
                        shaderc shaderc-devel \
                        pkg-config cmake git python3
                    ;;
                *)
                    die "unsupported OS: ID='${ID:-unknown}', ID_LIKE='${ID_LIKE:-unknown}'"
                    ;;
            esac
            ;;
    esac

    ok "package installation completed"
}

find_shaderc_lib_dir()
{
    local candidate=""

    if [[ -n "${SHADERC_LIB_DIR:-}" ]]; then
        if [[ -d "${SHADERC_LIB_DIR}" ]]; then
            printf '%s\n' "${SHADERC_LIB_DIR}"
            return 0
        fi
        warn "invalid SHADERC_LIB_DIR ignored: ${SHADERC_LIB_DIR}"
    fi

    if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists shaderc; then
        candidate="$(pkg-config --variable=libdir shaderc 2>/dev/null || true)"
        if [[ -n "${candidate}" && -d "${candidate}" ]]; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    fi

    for candidate in \
        /usr/lib64 \
        /usr/lib/x86_64-linux-gnu \
        /usr/lib/aarch64-linux-gnu \
        /usr/lib/arm-linux-gnueabihf \
        /usr/lib \
        /usr/local/lib64 \
        /usr/local/lib
    do
        if compgen -G "${candidate}/libshaderc*" > /dev/null 2>&1; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    done

    return 1
}

ensure_build_tooling()
{
    section "Build tooling"

    require_cmd cargo
    ok "cargo found"

    for tool in cmake git python3; do
        if command -v "${tool}" >/dev/null 2>&1; then
            ok "${tool} found"
        else
            warn "${tool} missing (needed if shaderc-sys falls back to source build)"
        fi
    done
}

run_cargo()
{
    local lib_dir="$1"
    local cargo_flags=()

    section "Cargo execution"

    [[ -n "${lib_dir}" ]] || die "empty shaderc lib dir"
    [[ -d "${lib_dir}" ]] || die "invalid shaderc lib dir: ${lib_dir}"
    [[ "${lib_dir}" = /* ]] || die "shaderc lib dir is not absolute: ${lib_dir}"
    [[ "${lib_dir}" != *$'\n'* ]] || die "shaderc lib dir contains newline"

    export SHADERC_LIB_DIR="${lib_dir}"

    kv "SHADERC_LIB_DIR" "${SHADERC_LIB_DIR}"

    if [[ "${DO_VERBOSE}" -eq 1 ]]; then
        cargo_flags+=("-vv")
        ok "verbose mode enabled"
    fi

    if [[ "${DO_CLEAN}" -eq 1 ]]; then
        step "cleaning cargo artifacts"
        cmd "cargo clean"
        cargo clean
        ok "cargo clean done"
    fi

    if [[ "${DO_BUILD}" -eq 1 ]]; then
        step "building package"
        cmd "cargo build ${cargo_flags[*]:-} -p ${PROJECT_PACKAGE}"
        exec cargo build "${cargo_flags[@]}" -p "${PROJECT_PACKAGE}"
    fi

    if [[ "${DO_RUN}" -eq 1 ]]; then
        step "running package"
        cmd "cargo run ${cargo_flags[*]:-} -p ${PROJECT_PACKAGE}"
        exec cargo run "${cargo_flags[@]}" -p "${PROJECT_PACKAGE}"
    fi

    ok "nothing else to do"
}

main()
{
    title "Testing script for vmnl"

    print_runtime_config
    ensure_build_tooling
    diagnostic_shaderc

    local lib_dir=""

    section "Shaderc discovery"
    if lib_dir="$(find_shaderc_lib_dir)"; then
        ok "shaderc library directory resolved"
        kv "resolved lib dir" "${lib_dir}"
        run_cargo "${lib_dir}"
    fi

    warn "shaderc not found, installation required"
    install_packages
    diagnostic_shaderc

    section "shaderc discovery after installation"
    if ! lib_dir="$(find_shaderc_lib_dir)"; then
        die "shaderc still not found after installation"
    fi

    ok "shaderc detected after installation"
    kv "resolved lib dir" "${lib_dir}"

    if [[ "${DO_CLEAN}" -eq 0 && "${DO_BUILD}" -eq 0 && "${DO_RUN}" -eq 1 ]]; then
        warn "forcing clean after fresh shaderc install"
        DO_CLEAN=1
    fi

    run_cargo "${lib_dir}"
}

main "$@"
