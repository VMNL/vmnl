#!/usr/bin/env bash

set -euo pipefail

PROJECT_PACKAGE="${PROJECT_PACKAGE:-test}"

DO_CLEAN=0
DO_RUN=1
DO_BUILD=0
DO_VERBOSE=0
DO_TESTS=0

usage()
{
    cat >&2 <<'EOF'
Usage: ./run.sh [-c | --clean] [-r | --run] [-b | --build] [-v | --verbose] [-t | --tests]

Options:
  -c | --clean    cargo clean only
  -r | --run      cargo clean + cargo run
  -b | --build    cargo build
  -v | --verbose  verbose cargo output (-vv)
  -t | --tests    run tests instead of examples

Default:
  cargo run
EOF
}

while getopts ":crbvt--clean--run--build--verbose--tests" opt; do
    case "${opt}" in
        c|--clean)
            DO_CLEAN=1
            DO_RUN=0
            DO_BUILD=0
            ;;
        r|--run)
            DO_CLEAN=1
            DO_RUN=1
            DO_BUILD=0
            ;;
        b|--build)
            DO_CLEAN=0
            DO_RUN=0
            DO_BUILD=1
            ;;
        v|--verbose)
            DO_VERBOSE=1
            ;;
        t|--tests)
            DO_TESTS=1
            DO_CLEAN=0
            DO_RUN=0
            DO_BUILD=0
            ;;
        \?)
            usage
            exit 1
            ;;
    esac
done

if [[ -t 2 ]]; then
    R=$'\033[0m'
    B=$'\033[1m'
    D=$'\033[2m'

    RED=$'\033[1;31m'
    GRN=$'\033[1;32m'
    YEL=$'\033[1;33m'
    BLU=$'\033[1;34m'
    MAG=$'\033[1;35m'
    CYA=$'\033[1;36m'
    WHT=$'\033[1;37m'
else
    R='' B='' D=''
    RED='' GRN='' YEL='' BLU='' MAG='' CYA='' WHT=''
fi

line()
{
    printf '%b\n' "${D}------------------------------------------------------------------------------${R}" >&2
}

title()
{
    line
    printf '%b\n' "${B}${MAG} $*${R}" >&2
    line
}

section()
{
    printf '\n%b\n' "${B}${CYA}==> $*${R}" >&2
}

ok()
{
    printf '%b\n' "${GRN}[Success]${R}  $*" >&2
}

warn()
{
    printf '%b\n' "${YEL}[Warning]${R}  $*" >&2
}

debug()
{
    printf '%b\n' "${D}· $*${R}" >&2
}

die()
{
    printf '%b\n' "${RED}[Error]${R}  $*" >&2
    exit 1
}

kv()
{
    local key="$1"
    local value="$2"
    printf '%b %b\n' "${WHT}${key}:${R}" "${value}" >&2
}

cmd()
{
    printf '%b %s\n' "${MAG}$${R}" "$*" >&2
}

step()
{
    printf '%b\n' "${B}${BLU}→${R}  $*" >&2
}

require_cmd()
{
    command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

load_os_release()
{
    [[ -r /etc/os-release ]] || die "/etc/os-release not found"
    # shellcheck disable=SC1091
    . /etc/os-release
}

print_runtime_config()
{
    section "Runtime configuration"
    kv "package" "${PROJECT_PACKAGE}"
    kv "clean"   "${DO_CLEAN}"
    kv "run"     "${DO_RUN}"
    kv "build"   "${DO_BUILD}"
    kv "verbose" "${DO_VERBOSE}"
    kv "tests"   "${DO_TESTS}"
}

diagnostic_shaderc()
{
    section "Shaderc diagnostics"
    if command -v pkg-config >/dev/null 2>&1; then
        ok "pkg-config detected"
    else
        warn "pkg-config not installed"
    fi
    if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists shaderc; then
        ok "pkg-config knows shaderc"
        kv "[Info] shaderc version" "$(pkg-config --modversion shaderc || true)"
        kv "[Info] shaderc libdir"  "$(pkg-config --variable=libdir shaderc || true)"
        kv "[Info] shaderc flags"   "$(pkg-config --libs --cflags shaderc || true)"
    else
        warn "pkg-config does not know shaderc"
    fi
    for path in \
        /usr/lib64 \
        /usr/lib/x86_64-linux-gnu \
        /usr/lib/aarch64-linux-gnu \
        /usr/lib/arm-linux-gnueabihf \
        /usr/lib \
        /usr/local/lib64 \
        /usr/local/lib
    do
        if compgen -G "${path}/libshaderc*" > /dev/null 2>&1; then
            ok "shaderc libraries found in ${path}"
            ls -1 "${path}"/libshaderc* 2>/dev/null >&2 || true
        else
            debug "no shaderc libraries in ${path}"
        fi
    done
}

install_packages()
{
    section "Installing system dependencies"

    load_os_release
    kv "ID"      "${ID:-unknown}"
    kv "ID_LIKE" "${ID_LIKE:-unknown}"

    case "${ID:-}" in
        fedora)
            cmd "sudo dnf install -y libshaderc-devel libshaderc-static pkgconf-pkg-config cmake git python3 ninja-build gcc-c++ make vulkan-loader-devel vulkan-tools glfw-devel wayland-devel libxkbcommon-devel libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel"
            sudo dnf install -y \
                libshaderc-devel libshaderc-static \
                pkgconf-pkg-config cmake git python3 ninja-build \
                gcc-c++ make \
                vulkan-loader-devel vulkan-tools \
                glfw-devel \
                wayland-devel libxkbcommon-devel \
                libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel
            ;;
        rhel|centos|rocky|almalinux)
            cmd "sudo dnf install -y shaderc-devel pkgconf-pkg-config cmake git python3 ninja-build gcc-c++ make vulkan-loader-devel vulkan-tools glfw-devel wayland-devel libxkbcommon-devel libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel"
            sudo dnf install -y \
                shaderc-devel \
                pkgconf-pkg-config cmake git python3 ninja-build \
                gcc-c++ make \
                vulkan-loader-devel vulkan-tools \
                glfw-devel \
                wayland-devel libxkbcommon-devel \
                libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel
            ;;
        ubuntu|debian)
            cmd "sudo apt-get update"
            sudo apt-get update
            cmd "sudo apt-get install -y libshaderc-dev pkg-config cmake git python3 ninja-build build-essential libvulkan-dev vulkan-tools libglfw3-dev libwayland-dev libxkbcommon-dev xorg-dev"
            sudo apt-get install -y \
                libshaderc-dev \
                pkg-config cmake git python3 ninja-build \
                build-essential \
                libvulkan-dev vulkan-tools \
                libglfw3-dev \
                libwayland-dev libxkbcommon-dev xorg-dev
            ;;
        arch)
            cmd "sudo pacman -Sy --needed shaderc pkgconf cmake git python ninja base-devel vulkan-headers vulkan-tools glfw wayland libxkbcommon libxcursor libxi libxinerama libxrandr"
            sudo pacman -Sy --needed \
                shaderc pkgconf cmake git python ninja \
                base-devel \
                vulkan-headers vulkan-tools \
                glfw \
                wayland libxkbcommon \
                libxcursor libxi libxinerama libxrandr
            ;;
        opensuse*|sles)
            cmd "sudo zypper --non-interactive install shaderc shaderc-devel pkg-config cmake git python3 ninja gcc-c++ make vulkan-devel vulkan-tools libglfw3-devel wayland-devel libxkbcommon-devel libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel"
            sudo zypper --non-interactive install \
                shaderc shaderc-devel \
                pkg-config cmake git python3 ninja \
                gcc-c++ make \
                vulkan-devel vulkan-tools \
                libglfw3-devel \
                wayland-devel libxkbcommon-devel \
                libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel
            ;;
        *)
            case "${ID_LIKE:-}" in
                *fedora*|*rhel*)
                    cmd "sudo dnf install -y shaderc-devel pkgconf-pkg-config cmake git python3 ninja-build gcc-c++ make vulkan-loader-devel vulkan-tools glfw-devel wayland-devel libxkbcommon-devel libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel"
                    sudo dnf install -y \
                        shaderc-devel \
                        pkgconf-pkg-config cmake git python3 ninja-build \
                        gcc-c++ make \
                        vulkan-loader-devel vulkan-tools \
                        glfw-devel \
                        wayland-devel libxkbcommon-devel \
                        libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel
                    ;;
                *debian*)
                    cmd "sudo apt-get update"
                    sudo apt-get update
                    cmd "sudo apt-get install -y libshaderc-dev pkg-config cmake git python3 ninja-build build-essential libvulkan-dev vulkan-tools libglfw3-dev libwayland-dev libxkbcommon-dev xorg-dev"
                    sudo apt-get install -y \
                        libshaderc-dev \
                        pkg-config cmake git python3 ninja-build \
                        build-essential \
                        libvulkan-dev vulkan-tools \
                        libglfw3-dev \
                        libwayland-dev libxkbcommon-dev xorg-dev
                    ;;
                *arch*)
                    cmd "sudo pacman -Sy --needed shaderc pkgconf cmake git python ninja base-devel vulkan-headers vulkan-tools glfw wayland libxkbcommon libxcursor libxi libxinerama libxrandr"
                    sudo pacman -Sy --needed \
                        shaderc pkgconf cmake git python ninja \
                        base-devel \
                        vulkan-headers vulkan-tools \
                        glfw \
                        wayland libxkbcommon \
                        libxcursor libxi libxinerama libxrandr
                    ;;
                *suse*)
                    cmd "sudo zypper --non-interactive install shaderc shaderc-devel pkg-config cmake git python3 ninja gcc-c++ make vulkan-devel vulkan-tools libglfw3-devel wayland-devel libxkbcommon-devel libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel"
                    sudo zypper --non-interactive install \
                        shaderc shaderc-devel \
                        pkg-config cmake git python3 ninja \
                        gcc-c++ make \
                        vulkan-devel vulkan-tools \
                        libglfw3-devel \
                        wayland-devel libxkbcommon-devel \
                        libXcursor-devel libXi-devel libXinerama-devel libXrandr-devel
                    ;;
                *)
                    die "unsupported OS: ID='${ID:-unknown}', ID_LIKE='${ID_LIKE:-unknown}'"
                    ;;
            esac
            ;;
    esac

    ok "system dependencies installation completed"
}

find_shaderc_lib_dir()
{
    local candidate=""

    if [[ -n "${SHADERC_LIB_DIR:-}" ]]; then
        if [[ -d "${SHADERC_LIB_DIR}" ]]; then
            printf '%s\n' "${SHADERC_LIB_DIR}"
            return 0
        fi
        warn "invalid SHADERC_LIB_DIR ignored: ${SHADERC_LIB_DIR}"
    fi
    if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists shaderc; then
        candidate="$(pkg-config --variable=libdir shaderc 2>/dev/null || true)"
        if [[ -n "${candidate}" && -d "${candidate}" ]]; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    fi
    for candidate in \
        /usr/lib64 \
        /usr/lib/x86_64-linux-gnu \
        /usr/lib/aarch64-linux-gnu \
        /usr/lib/arm-linux-gnueabihf \
        /usr/lib \
        /usr/local/lib64 \
        /usr/local/lib
    do
        if compgen -G "${candidate}/libshaderc*" > /dev/null 2>&1; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    done
    return 1
}

ensure_build_tooling()
{
    section "Build tooling"
    require_cmd cargo
    ok "cargo found"
    require_cmd cc
    ok "C compiler (cc) found"
    require_cmd c++
    ok "C++ compiler (c++) found"
    for tool in cmake git python3; do
        if command -v "${tool}" >/dev/null 2>&1; then
            ok "${tool} found"
        else
            warn "${tool} missing (required for shaderc-sys fallback build)"
        fi
    done
    if command -v ninja >/dev/null 2>&1; then
        ok "ninja found"
    else
        debug "ninja missing (optional on Linux, useful for source builds)"
    fi
    if command -v pkg-config >/dev/null 2>&1; then
        ok "pkg-config found"
    else
        warn "pkg-config missing (system shaderc/glfw detection will likely fail)"
    fi
    if command -v vulkaninfo >/dev/null 2>&1; then
        ok "vulkaninfo found (vulkan-tools)"
    else
        debug "vulkaninfo missing (optional, useful for Vulkan diagnostics)"
    fi
    if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists shaderc; then
        ok "shaderc detected via pkg-config"
    else
        warn "shaderc not found via pkg-config (shaderc-sys may fall back to source build)"
    fi
    if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists glfw3; then
        ok "GLFW detected via pkg-config"
    else
        warn "GLFW not found via pkg-config"
        debug "(not necessarily a problem if build succeeds)"
    fi
}

run_cargo()
{
    local lib_dir="$1"
    local cargo_flags=()

    section "Cargo execution"
    [[ -n "${lib_dir}" ]] || die "empty shaderc lib dir"
    [[ -d "${lib_dir}" ]] || die "invalid shaderc lib dir: ${lib_dir}"
    [[ "${lib_dir}" = /* ]] || die "shaderc lib dir is not absolute: ${lib_dir}"
    [[ "${lib_dir}" != *$'\n'* ]] || die "shaderc lib dir contains newline"
    export SHADERC_LIB_DIR="${lib_dir}"
    kv "SHADERC_LIB_DIR" "${SHADERC_LIB_DIR}"
    if [[ "${DO_VERBOSE}" -eq 1 ]]; then
        cargo_flags+=("-vv")
        ok "verbose mode enabled"
    fi
    if [[ "${DO_CLEAN}" -eq 1 ]]; then
        step "cleaning cargo artifacts"
        cmd "cargo clean"
        cargo clean
        ok "cargo clean done"
    fi
    if [[ "${DO_BUILD}" -eq 1 ]]; then
        step "building package"
        cmd "cargo build ${cargo_flags[*]:-} -p ${PROJECT_PACKAGE}"
        exec cargo build "${cargo_flags[@]}" -p "${PROJECT_PACKAGE}"
    fi
    if [[ "${DO_RUN}" -eq 1 ]]; then
        step "running package"
        cmd "cargo run ${cargo_flags[*]:-} -p ${PROJECT_PACKAGE}"
        exec cargo run "${cargo_flags[@]}" -p "${PROJECT_PACKAGE}"
    fi
    ok "nothing else to do"
}

main()
{
    title "Testing script for vmnl"
    print_runtime_config
    ensure_build_tooling
    diagnostic_shaderc

    local lib_dir=""

    section "Shaderc discovery"
    if lib_dir="$(find_shaderc_lib_dir)"; then
        ok "shaderc library directory resolved"
        kv "[Info] resolved lib dir" "${lib_dir}"
        if [[ "${DO_TESTS}" -eq 1 ]]; then
            exec cargo test -p vmnl_native --lib
        else
            run_cargo "${lib_dir}"
        fi
    fi

    warn "shaderc not found, installation required"
    install_packages
    diagnostic_shaderc
    section "shaderc discovery after installation"
    if ! lib_dir="$(find_shaderc_lib_dir)"; then
        die "shaderc still not found after installation"
    fi
    ok "shaderc detected after installation"
    kv "[Info] resolved lib dir" "${lib_dir}"
    if [[ "${DO_CLEAN}" -eq 0 && "${DO_BUILD}" -eq 0 && "${DO_RUN}" -eq 1 ]]; then
        warn "forcing clean after fresh shaderc install"
        DO_CLEAN=1
    fi
    if [[ "${DO_TESTS}" -eq 1 ]]; then
        cargo test -p vmnl_native --lib
    else
        run_cargo "${lib_dir}"
    fi
}

main "$@"
